# FocusReader production env — copy to deploy/.env and fill in.
# NEVER commit the filled-in file.

# Your apex domain (Caddy serves app.<DOMAIN> and api.<DOMAIN>)
DOMAIN=focusreader.example.com

# --- Frontend ---
NEXT_PUBLIC_APP_URL=https://app.focusreader.example.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PREMIUM_PRICE_ID=price_...

# --- Shared secret between frontend proxy and TTS engine ---
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_SECRET=

# --- Backend (TTS engine) ---
# Production voice: set ONE of these. (macOS `say` does not exist on Linux.)
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# OPEN_SOURCE_TTS_URL=http://kokoro:8880/v1/audio/speech

# CORS: which origins may call the metered /api/tts endpoints directly
CORS_ORIGIN=https://app.focusreader.example.com
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
