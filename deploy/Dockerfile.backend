# FocusReader TTS engine — Express + ffmpeg
FROM node:22-alpine
WORKDIR /app
# ffmpeg: speed change + noise-bed mixing. Native toolchain for better-sqlite3.
RUN apk add --no-cache ffmpeg python3 make g++
COPY package.json package-lock.json ./
RUN npm ci --omit=dev && apk del python3 make g++
COPY src ./src
ENV NODE_ENV=production
ENV DATA_DIR=/data
ENV TRUST_PROXY=1
EXPOSE 4000
CMD ["node", "src/index.js"]
