{
  "manifest_version": 3,
  "name": "Zhavior FocusReader",
  "version": "2.0.0",
  "description": "The official Zhavior hyper-focus extension. AI-powered Bionic Reading, premium TTS, and smart article summarization.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://localhost:3001/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Zhavior FocusReader"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
