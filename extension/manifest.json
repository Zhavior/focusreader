{
  "manifest_version": 3,
  "name": "Hyperfi Reader",
  "version": "3.0.3",
  "description": "Read any article with hyper-focus: karaoke TTS, Bionic Reading, and focus soundscapes — built for ADHD brains.",
  "permissions": [
    "storage",
    "offscreen",
    "cookies"
  ],
  "host_permissions": [
    "http://localhost:3001/*",
    "http://localhost:4000/*",
    "https://*.hyperfi.ai/*",
    "https://*.hyperfi.app/*",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Hyperfi Reader",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "config.js",
        "content.js",
        "gemini-voice.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["library.html", "offscreen.html", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}