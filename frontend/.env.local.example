# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Existing ElevenLabs pipeline (Express backend) — server-side only
TTS_BACKEND_URL=http://localhost:4000
# Shared secret guarding the TTS engine. MUST match INTERNAL_API_SECRET in
# backend/.env. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_SECRET=replace_with_a_long_random_string

# Clerk (https://dashboard.clerk.com → API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
# Price ID of the $19/month recurring price (Products -> Premium -> Pricing)
STRIPE_PREMIUM_PRICE_ID=price_your_premium_price_id

# LemonSqueezy (https://app.lemonsqueezy.com -> Settings -> API)
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_api_key
LEMONSQUEEZY_STORE_ID=your_store_id
LEMONSQUEEZY_WEBHOOK_SECRET=your_lemonsqueezy_webhook_secret

# Production Cloud Database (PostgreSQL / Neon / Supabase)
DATABASE_URL=postgresql://user:password@cloud-db.neon.tech/focusreader?sslmode=require
