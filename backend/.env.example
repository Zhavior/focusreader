# ==========================================
# Hyperfi Voice Backend — Production Environment Variables
# ==========================================

# Port and Proxy Configuration
PORT=4000
TRUST_PROXY=1
CORS_ORIGIN=https://app.hyperfi.ai,https://hyperfi.ai,http://localhost:3001

# Database Configuration (PostgreSQL / Neon / Supabase in Prod, SQLite in Dev)
DATABASE_URL=postgresql://user:password@cloud-db.neon.tech/focusreader?sslmode=require
# If DATABASE_URL is not provided, the backend falls back to local SQLite at DATA_DIR
DATA_DIR=/var/data/hyperfi

# Audio Storage & Caching Layer (R2 / GCS / Local Mount)
AUDIO_CACHE_DIR=/var/data/hyperfi/audio_cache

# ElevenLabs & Fallback TTS Providers
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ENABLE_EDGE_TTS=true
ENABLE_LOCAL_TTS=true
ENABLE_OPENSOURCE_TTS=true

# Security & Webhook Signatures
INTERNAL_API_SECRET=your_super_secret_internal_auth_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_secret_here
LEMONSQUEEZY_WEBHOOK_SECRET=your_lemonsqueezy_webhook_secret_here
