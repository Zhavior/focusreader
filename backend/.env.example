PORT=4000
NODE_ENV=development

# CORS: comma-separated list of allowed origins for the frontend
CORS_ORIGIN=http://localhost:3000

# Shared secret between the Next.js server and this TTS engine. MUST match
# INTERNAL_API_SECRET in the frontend's .env.local. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_SECRET=replace_with_a_long_random_string

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20

# Voice provider: "local" uses macOS's built-in `say` engine — free, no key
# needed (great for development). Remove this line (and set a real
# ELEVENLABS_API_KEY) to switch to ElevenLabs voices.
TTS_PROVIDER=local
# Optional: pick a specific macOS voice, e.g. Samantha (run `say -v ?` to list)
# LOCAL_TTS_VOICE=Samantha
